class node:
  def __init__(self, data):
      self.data = data
      self.left = None
      self.right = None

def check_binary_search_tree_(root):
    return validate_bst(root, float('-inf'), float('inf'))
    
def validate_bst(node, min_val, max_val):
    if node is None:
        return True
        
    if node.data <= min_val or node.data >= max_val:
        return False
    
    return (validate_bst(node.left, min_val, node.data) and validate_bst(node.right, node.data, max_val))
